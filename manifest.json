{
  "name": "Freight Logic",
  "short_name": "Freight Logic",
  "xpedite_version": "10.2.0",
  "description": "Offline-first freight finance & logistics tracker (personal PWA).",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#FFB300",
  "background_color": "#0a0a0a",
  "icons": [
    {
      "src": "icon192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "./?share-target=true",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "receipts",
          "accept": [
            "image/jpeg",
            "image/png",
            "image/webp",
            "image/*"
          ]
        }
      ]
    }
  },
  "categories": [
    "business",
    "finance",
    "productivity"
  ],
  "shortcuts": [
    {
      "name": "Add Trip",
      "short_name": "New Trip",
      "description": "Quickly log a new trip",
      "url": "./?action=newtrip",
      "icons": [
        {
          "src": "icon192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Load Simulator",
      "short_name": "Simulate",
      "description": "Evaluate a load before accepting",
      "url": "./?action=simulator",
      "icons": [
        {
          "src": "icon192.png",
          "sizes": "192x192"
        }
      ]
    }
  ]
}